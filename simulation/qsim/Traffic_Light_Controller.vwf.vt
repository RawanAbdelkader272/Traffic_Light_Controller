always @(G_E_expected or G_E or G_N_expected or G_N or R_E_expected or R_E or R_N_expected or R_N or Y_E_expected or Y_E or Y_N_expected or Y_N or digit_sel_expected or digit_sel or seg_expected or seg)
begin
