module traffic_light_controller_vlg_vec_tst();
// constants                                           
// general purpose registers
reg clk;
reg reset_n;
reg sensor_E;
reg sensor_N;
// wires                                               
wire G_E;
wire G_N;
wire R_E;
wire R_N;
wire Y_E;
wire Y_N;
wire [1:0] digit_sel;
wire [6:0] seg;

wire sampler;                             

// assign statements (if any)                          
traffic_light_controller i1 (
// port map - connection between master ports and signals/registers   
	.G_E(G_E),
	.G_N(G_N),
	.R_E(R_E),
	.R_N(R_N),
	.Y_E(Y_E),
	.Y_N(Y_N),
	.clk(clk),
	.digit_sel(digit_sel),
	.reset_n(reset_n),
	.seg(seg),
	.sensor_E(sensor_E),
	.sensor_N(sensor_N)
);

// clk
always
begin
	clk = 1'b0;
	clk = #5000 1'b1;
	#5000;
end 

// reset_n
initial
begin
	reset_n = 1'b0;
	reset_n = #90000 1'b1;
	reset_n = #700000 1'b0;
	reset_n = #120000 1'b1;
end 

// sensor_E
initial
begin
	sensor_E = 1'b1;
	sensor_E = #280000 1'b0;
	sensor_E = #168000 1'b1;
	sensor_E = #112000 1'b0;
	sensor_E = #56000 1'b1;
	sensor_E = #112000 1'b0;
	sensor_E = #168000 1'b1;
end 

// sensor_N
initial
begin
	sensor_N = 1'b1;
	sensor_N = #546000 1'b0;
	sensor_N = #78000 1'b1;
	sensor_N = #156000 1'b0;
	sensor_N = #78000 1'b1;
	sensor_N = #78000 1'b0;
end 

traffic_light_controller_vlg_sample_tst tb_sample (
	.clk(clk),
	.reset_n(reset_n),
	.sensor_E(sensor_E),
	.sensor_N(sensor_N),
	.sampler_tx(sampler)
);

traffic_light_controller_vlg_check_tst tb_out(
	.G_E(G_E),
	.G_N(G_N),
	.R_E(R_E),
	.R_N(R_N),
	.Y_E(Y_E),
	.Y_N(Y_N),
	.digit_sel(digit_sel),
	.seg(seg),
	.sampler_rx(sampler)
);
endmodule

