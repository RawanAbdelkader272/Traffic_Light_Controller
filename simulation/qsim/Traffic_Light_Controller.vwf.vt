always @(posedge sampler_rx or negedge sampler_rx)
begin
`ifdef debug_tbench
	$display("Scanning pattern %d @time = %t",i,$realtime );
	i = i + 1;
	$display("| expected G_E = %b | expected G_N = %b | expected R_E = %b | expected R_N = %b | expected Y_E = %b | expected Y_N = %b | expected digit_sel = %b | expected seg = %b | ",G_E_expected_prev,G_N_expected_prev,R_E_expected_prev,R_N_expected_prev,Y_E_expected_prev,Y_N_expected_prev,digit_sel_expected_prev,seg_expected_prev);
	$display("| real G_E = %b | real G_N = %b | real R_E = %b | real R_N = %b | real Y_E = %b | real Y_N = %b | real digit_sel = %b | real seg = %b | ",G_E_prev,G_N_prev,R_E_prev,R_N_prev,Y_E_prev,Y_N_prev,digit_sel_prev,seg_prev);
