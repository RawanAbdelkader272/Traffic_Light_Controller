`timescale 1 ps/ 1 ps
module traffic_light_controller_vlg_sample_tst(
	clk,
	reset_n,
	sensor_E,
	sensor_N,
	sampler_tx
);
input  clk;
input  reset_n;
input  sensor_E;
input  sensor_N;
output sampler_tx;

reg sample;
time current_time;
always @(clk or reset_n or sensor_E or sensor_N)
                                                                                
begin                                                 
 if ($realtime > 0)                                   
 begin                                                
	if ($realtime == 0 || $realtime != current_time)  
	begin									          
		if (sample === 1'bx)                          
			sample = 0;                               
		else                                          
			sample = ~sample;                         
	end										          
	current_time = $realtime;					      
 end                                                  
end                                                   

assign sampler_tx = sample;
endmodule

module traffic_light_controller_vlg_check_tst (
	G_E,
	G_N,
	R_E,
	R_N,
	Y_E,
	Y_N,
	digit_sel,
	seg,
	sampler_rx
